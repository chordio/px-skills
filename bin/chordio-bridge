#!/usr/bin/env bash
# chordio-bridge — keep gstack's design skills patched with chordio's taste references.
#
# Intended to run as a Claude Code SessionStart hook so that gstack upgrades
# (which regenerate SKILL.md files and would clobber any direct edits) are
# detected and re-patched automatically on the next Claude session.
#
# Always exits 0 — must never block a session.
#
# Usage:
#   chordio-bridge              # patch if needed, log if anything changed
#   chordio-bridge --quiet      # no output unless a re-patch happens (hook mode)
#   chordio-bridge --check      # report state, never write
#   chordio-bridge --dry-run    # show what would happen, never write
#   chordio-bridge --force      # re-patch all targets regardless of state

set +e
umask 077

BRIDGE_VERSION="1"
CHORDIO_ROOT="${CHORDIO_ROOT:-$HOME/.claude-design-skills}"
GSTACK_SKILLS_ROOT="${GSTACK_SKILLS_ROOT:-$HOME/.claude/skills/gstack}"
STATE_FILE="${CHORDIO_BRIDGE_STATE:-$CHORDIO_ROOT/.bridge-state}"

# gstack design skills that benefit from chordio taste injection.
TARGETS=(
  design-review
  plan-design-review
  design-consultation
  design-shotgun
  design-html
)

QUIET=0
DRY_RUN=0
CHECK_ONLY=0
FORCE=0
for arg in "$@"; do
  case "$arg" in
    --quiet)   QUIET=1 ;;
    --dry-run) DRY_RUN=1 ;;
    --check)   CHECK_ONLY=1 ;;
    --force)   FORCE=1 ;;
    -h|--help)
      sed -n '2,15p' "$0"
      exit 0
      ;;
  esac
done

log() { [ "$QUIET" -eq 0 ] && printf '[chordio-bridge] %s\n' "$*" >&2; }
warn() { printf '[chordio-bridge] warning: %s\n' "$*" >&2; }

# ─── Pre-flight: silent no-op if either side is missing ─────────────────
if [ ! -d "$GSTACK_SKILLS_ROOT" ]; then
  [ "$CHECK_ONLY" -eq 1 ] && log "gstack not installed at $GSTACK_SKILLS_ROOT — nothing to bridge"
  exit 0
fi

if [ ! -d "$CHORDIO_ROOT/shared/design-taste" ]; then
  warn "chordio taste refs missing at $CHORDIO_ROOT/shared/design-taste — skipping"
  exit 0
fi

# ─── The block we inject into each gstack SKILL.md.tmpl ────────────────
BLOCK_BEGIN="<!-- BEGIN chordio-taste v${BRIDGE_VERSION} -->"
BLOCK_END="<!-- END chordio-taste -->"

BLOCK_FILE="$(mktemp -t chordio-bridge-block.XXXXXX)"
trap 'rm -f "$BLOCK_FILE"' EXIT

cat > "$BLOCK_FILE" <<EOF
${BLOCK_BEGIN}
**Chordio design-taste references (loaded by claude-design-skills bridge):**

Before doing anything else, read these and apply them as authoritative guidance for the rest of this skill:

- \`~/.claude-design-skills/shared/design-taste/anti-patterns.md\` — patterns to refuse on sight
- \`~/.claude-design-skills/shared/design-taste/heuristics-scoring.md\` — Nielsen's 10 heuristics with 0–4 severity rubric
- \`~/.claude-design-skills/shared/design-taste/typography.md\`, \`color-and-contrast.md\`, \`spatial-design.md\`, \`motion-design.md\`, \`interaction-design.md\`, \`responsive-design.md\`, \`ux-writing.md\` — domain references; read whichever are relevant

Also read \`./design-context/*.md\` from the working project if present.

If \`~/.claude-design-skills/\` is missing on this machine, ignore this block and continue with gstack's built-in references.
${BLOCK_END}
EOF

BLOCK_HASH=$(shasum -a 256 "$BLOCK_FILE" | awk '{print $1}')

# ─── State file (flat key=value, simple to read in bash) ───────────────
read_state() {
  local key="$1"
  [ -f "$STATE_FILE" ] || return 0
  grep "^${key}=" "$STATE_FILE" 2>/dev/null | tail -1 | cut -d= -f2-
}

write_state() {
  local key="$1" val="$2"
  mkdir -p "$(dirname "$STATE_FILE")"
  local tmp="$STATE_FILE.tmp.$$"
  if [ -f "$STATE_FILE" ]; then
    grep -v "^${key}=" "$STATE_FILE" 2>/dev/null > "$tmp" || true
  else
    : > "$tmp"
  fi
  printf '%s=%s\n' "$key" "$val" >> "$tmp"
  mv "$tmp" "$STATE_FILE"
}

# ─── Patcher: strip any existing block, inject fresh block after frontmatter ─
patch_file() {
  local file="$1"
  [ -f "$file" ] || return 1

  local tmp="${file}.chordio.$$"
  awk -v end="$BLOCK_END" \
      -v block_file="$BLOCK_FILE" '
    BEGIN {
      n = 0
      while ((getline line < block_file) > 0) block_lines[++n] = line
      close(block_file)
      in_old_block = 0
      dashes = 0
      injected = 0
    }
    # Strip any prior chordio-taste block (any version)
    /^<!-- BEGIN chordio-taste/ { in_old_block = 1; next }
    in_old_block && $0 == end { in_old_block = 0; next }
    in_old_block { next }
    # Inject fresh block after the closing --- of the YAML frontmatter
    /^---$/ {
      print
      dashes++
      if (dashes == 2 && !injected) {
        print ""
        for (i = 1; i <= n; i++) print block_lines[i]
        injected = 1
      }
      next
    }
    { print }
  ' "$file" > "$tmp"

  if [ ! -s "$tmp" ]; then
    rm -f "$tmp"
    return 1
  fi

  mv "$tmp" "$file"
  return 0
}

hash_file() { shasum -a 256 "$1" 2>/dev/null | awk '{print $1}'; }

# ─── Decide whether the whole bridge needs forcing ─────────────────────
saved_bridge_version=$(read_state "bridge_version")
saved_block_hash=$(read_state "block_hash")

global_force=$FORCE
if [ "$saved_bridge_version" != "$BRIDGE_VERSION" ] || \
   [ "$saved_block_hash" != "$BLOCK_HASH" ]; then
  global_force=1
fi

# ─── Per-target loop ───────────────────────────────────────────────────
patched=0
up_to_date=0
missing=0

for name in "${TARGETS[@]}"; do
  tmpl="$GSTACK_SKILLS_ROOT/$name/SKILL.md.tmpl"
  rendered="$GSTACK_SKILLS_ROOT/$name/SKILL.md"

  if [ ! -f "$tmpl" ]; then
    missing=$((missing+1))
    [ "$CHECK_ONLY" -eq 1 ] && log "$name: tmpl missing"
    continue
  fi

  current_tmpl_hash=$(hash_file "$tmpl")
  saved_tmpl_hash=$(read_state "tmpl_hash_$name")
  current_rendered_hash=""
  [ -f "$rendered" ] && current_rendered_hash=$(hash_file "$rendered")
  saved_rendered_hash=$(read_state "rendered_hash_$name")

  needs_patch=0
  if [ "$global_force" -eq 1 ]; then
    needs_patch=1
  elif [ "$current_tmpl_hash" != "$saved_tmpl_hash" ]; then
    needs_patch=1
  elif [ -n "$current_rendered_hash" ] && [ "$current_rendered_hash" != "$saved_rendered_hash" ]; then
    needs_patch=1
  fi

  if [ "$needs_patch" -eq 0 ]; then
    up_to_date=$((up_to_date+1))
    [ "$CHECK_ONLY" -eq 1 ] && log "$name: up to date"
    continue
  fi

  if [ "$CHECK_ONLY" -eq 1 ]; then
    log "$name: would re-patch"
    continue
  fi
  if [ "$DRY_RUN" -eq 1 ]; then
    log "$name: would re-patch (dry run)"
    continue
  fi

  patch_file "$tmpl" || { warn "$name: failed to patch tmpl"; continue; }
  if [ -f "$rendered" ]; then
    patch_file "$rendered" || warn "$name: failed to patch rendered (continuing)"
  fi

  write_state "tmpl_hash_$name" "$(hash_file "$tmpl")"
  [ -f "$rendered" ] && write_state "rendered_hash_$name" "$(hash_file "$rendered")"
  patched=$((patched+1))
  log "patched $name"
done

if [ "$CHECK_ONLY" -eq 0 ] && [ "$DRY_RUN" -eq 0 ]; then
  write_state "bridge_version" "$BRIDGE_VERSION"
  write_state "block_hash" "$BLOCK_HASH"
fi

if [ "$patched" -gt 0 ]; then
  log "patched $patched, up to date $up_to_date, missing $missing"
elif [ "$QUIET" -eq 0 ]; then
  log "all up to date ($up_to_date targets, $missing missing)"
fi

exit 0
